# EmailJS 設定（複製此檔為 .env 並填入你的金鑰）
# 1. 前往 https://www.emailjs.com 建立免費帳號
# 2. 建立一個 Email Service（選擇 Gmail 或 SMTP）
# 3. 建立一個 Email Template，Template 中加入以下變數：
#    {{from_name}} {{from_email}} {{company}} {{budget}} {{services}} {{message}}
#    設定 To Email: hc@pixelholic.co, katie@pixelholic.co
# 4. 將以下三個 ID 填入

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
